    background-color: #f4f4f4;
    color: #1a1a1a;
    font-size: 14px;
    line-height: 1.7;
  }
  .container {
    max-width: 620px;
    margin: 20px auto;
    background-color: #ffffff;
  }
  .header {
    background-color: #ffffff;
    padding: 22px 30px;
    text-align: left;
    border-bottom: 1px solid #e0e6ed;
  }
  .header .logo-img {
    display: block;
    width: 60px;
    height: auto;
  }
  .hero {
    background: linear-gradient(135deg, #006fcf 0%, #00175a 100%);
    padding: 45px 30px;
    text-align: center;
    color: #ffffff;
  }
  .hero .label {
    display: inline-block;
    background-color: #ffffff;
    color: #006fcf;
    padding: 5px 16px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    margin-bottom: 18px;
    border-radius: 2px;
  }
  .hero h1 {
    font-size: 26px;
    font-weight: 700;
    margin: 0 0 15px 0;
    line-height: 1.4;
  }
  .points {
    font-size: 56px;
    font-weight: 700;
    color: #ffd700;
    letter-spacing: -1px;
    margin: 15px 0 5px 0;
    font-family: "Helvetica Neue", Arial, sans-serif;
  }
  .points-unit {
    font-size: 18px;
    color: #ffffff;
    margin-bottom: 10px;
  }
  .hero .subtitle {
    font-size: 14px;
    color: #cce0f5;
    margin-top: 10px;
  }
  .countdown {
    background-color: #fff8e1;
    border-top: 1px solid #ffd700;
    border-bottom: 1px solid #ffd700;
    padding: 15px;
    text-align: center;
    color: #b8860b;
    font-size: 14px;
    font-weight: 700;
  }
  .content {
    padding: 35px 30px;
  }
  .greeting {
    font-size: 14px;
    color: #1a1a1a;
    margin-bottom: 18px;
  }
  .lead {
    font-size: 14px;
    color: #444;
    margin-bottom: 25px;
  }
  h2 {
    font-size: 17px;
    font-weight: 700;
    color: #00175a;
    border-left: 4px solid #006fcf;
    padding-left: 12px;
    margin: 30px 0 15px 0;
  }
  .conditions {
    background-color: #f7f9fc;
    border: 1px solid #e0e6ed;
    padding: 20px 25px;
    margin: 15px 0;
  }
  .conditions table {
    width: 100%;
    border-collapse: collapse;
  }
  .conditions th, .conditions td {
    padding: 10px 0;
    text-align: left;
    font-size: 13px;
    border-bottom: 1px dashed #d0d7e2;
    vertical-align: top;
  }
  .conditions th {
    color: #006fcf;
    font-weight: 700;
    width: 35%;
    white-space: nowrap;
  }
  .conditions tr:last-child th, .conditions tr:last-child td {
    border-bottom: none;
  }
  .steps {
    counter-reset: step;
    padding: 0;
    list-style: none;
  }
  .steps li {
    counter-increment: step;
    padding: 15px 15px 15px 55px;
    position: relative;
    background-color: #f7f9fc;
    margin-bottom: 8px;
    font-size: 13px;
  }
  .steps li::before {
    content: "STEP " counter(step);
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    background-color: #006fcf;
    color: #ffffff;
    font-size: 9px;
    font-weight: 700;
    padding: 4px 6px;
    letter-spacing: 0.5px;
  }
  .button-area {
    text-align: center;
    margin: 30px 0;
  }
  .button {
    display: inline-block;
    background-color: #006fcf;
    color: #ffffff !important;
    padding: 16px 50px;
    text-decoration: none;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 1px;
    border: 2px solid #006fcf;
  }
  .button:hover {
    background-color: #00175a;
  }
  .notice {
    background-color: #fffbf3;
    border: 1px solid #f0c14b;
    padding: 15px 18px;
    margin: 20px 0;
    font-size: 12px;
    color: #6b5818;
    line-height: 1.7;
  }
  .notice strong {
    display: block;
    color: #b8860b;
    margin-bottom: 6px;
    font-size: 13px;
  }
  .terms {
    font-size: 11px;
    color: #888;
    line-height: 1.7;
    margin-top: 20px;
    padding-top: 15px;
    border-top: 1px solid #e0e6ed;
  }
  .terms li {
    margin-bottom: 5px;
  }
  .footer {
    background-color: #00175a;
    padding: 25px 30px;
    text-align: center;
    color: #cce0f5;
    font-size: 11px;
    line-height: 1.8;
  }
  .footer a {
    color: #ffffff;
    text-decoration: none;
    margin: 0 8px;
  }
  .footer .copyright {
    margin-top: 15px;
    color: #8da7c4;
    font-size: 10px;
  }
