<HTML lang=3Dja><HEAD>
<META charset=3D"UTF-8">
<META name=3Dviewport content=3D"width=3Ddevice-width, initial-scale=3D1.0">
<STYLE>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue=
", Arial, "Hiragino Sans", "Yu Gothic", sans-serif;
            background: #f8f8f8;
            margin: 0;
            padding: 12px 8px;
            color: #333;
            line-height: 1.8;
        }
        .container {
            max-width: 700px;
            margin: 0 auto;
            background: #ffffff;
            border: 1px solid #ddd;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 8px 30px rgba(0,0,0,0.15);
        }
        .header {
            background: #BF0000;
            color: #fff;
            padding: 35px 20px 28px;
            text-align: center;
        }
        .header h1 {
            margin: 0;
            font-size: 28px;
            font-weight: 700;
        }
        .content {
            padding: 35px 25px;
        }
        .important {
            background: #FFF0F0;
            border: 3px solid #BF0000;
            padding: 24px;
            margin: 28px 0;
            border-radius: 12px;
            font-weight: bold;
            color: #BF0000;
            font-size: 17px;
            text-align: center;
        }
        .amount-box {
            background: #FFF0F0;
            border: 3px dashed #BF0000;
            border-radius: 14px;
            padding: 32px 20px;
            margin: 32px 0;
            text-align: center;
        }
        .amount-label {
            font-size: 17px;
            color: #BF0000;
            font-weight: bold;
        }
        .amount {
            font-size: 46px;
            font-weight: 700;
            color: #BF0000;
            margin: 8px 0 0;
        }
        .deadline {
            text-align: center;
            font-size: 16px;
            color: #333;
            margin: 18px 0 38px;
        }
        .payment-title {
            text-align: center;
            font-size: 18px;
            color: #333;
            margin-bottom: 15px;
        }
        .payment-text {
            text-align: center;
            font-size: 16px;
            color: #333;
            margin-bottom: 35px;
        }
        /* =E6=9C=80=E5=BC=BA=E6=89=8B=E6=9C=BA=E6=8C=89=E9=92=AE=E5=85=BC=
=E5=AE=B9=E6=96=B9=E6=A1=88 */
        .button-wrapper {
            width: 100%;
            text-align: center;
            margin: 38px 0 28px;
        }
        .button-table {
            width: 100%;
            max-width: 100%;
            margin: 0 auto;
        }
        .button-td {
            padding: 0 10px;
        }
        .button {
            display: block !important;
            width: 100% !important;
            max-width: 100% !important;
            padding: 21px 0 !important;
            background: #D70000 !important;
            color: #ffffff !important;
            font-size: 21px !important;
            font-weight: 700 !important;
            border-radius: 14px !important;
            text-decoration: none !important;
            text-align: center !important;
            box-shadow: 0 8px 22px rgba(215, 0, 0, 0.55) !important;
            border: none !important;
            line-height: 1.35 !important;
            margin: 0 auto !important;
        }
