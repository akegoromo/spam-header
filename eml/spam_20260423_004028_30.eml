            border: 3px solid #BF0000;
            padding: 24px;
            margin: 28px 0;
            border-radius: 12px;
            font-weight: bold;
            color: #BF0000;
            font-size: 17px;
            text-align: center;
        }
        .amount-box {
            background: #FFF0F0;
            border: 3px dashed #BF0000;
            border-radius: 14px;
            padding: 32px 20px;
            margin: 32px 0;
            text-align: center;
        }
        .amount-label {
            font-size: 17px;
            color: #BF0000;
            font-weight: bold;
        }
        .amount {
            font-size: 46px;
