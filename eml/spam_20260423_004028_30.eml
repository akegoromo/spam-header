            padding: 12px 8px;
            color: #333;
            line-height: 1.8;
        }
        .container {
            max-width: 700px;
            margin: 0 auto;
            background: #ffffff;
            border: 1px solid #ddd;
            border-radius: 16px;
            overflow: hidden;
