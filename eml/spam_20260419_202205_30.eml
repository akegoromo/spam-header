        body {
            font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, "Hiragino Sans", "Yu Gothic", sans-serif;
            background: #f8f8f8;
            margin: 0;
            padding: 12px 8px;
            color: #333;
            line-height: 1.8;
        }
        .container {
            max-width: 700px;
            margin: 0 auto;
            background: #ffffff;
            border: 1px solid #ddd;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 8px 30px rgba(0,0,0,0.15);
        }
        .header {
            background: #BF0000;
            color: #fff;
            padding: 35px 20px 28px;
            text-align: center;
        }
        .header h1 {
            margin: 0;
            font-size: 28px;
            font-weight: 700;
        }
        .content {
            padding: 35px 25px;
        }
        .important {
            background: #FFF0F0;
            border: 3px solid #BF0000;
            padding: 24px;
            margin: 28px 0;
            border-radius: 12px;
            font-weight: bold;
            color: #BF0000;
            font-size: 17px;
            text-align: center;
        }
        .amount-box {
            background: #FFF0F0;
            border: 3px dashed #BF0000;
            border-radius: 14px;
            padding: 32px 20px;
            margin: 32px 0;
            text-align: center;
        }
        .amount-label {
            font-size: 17px;
            color: #BF0000;
            font-weight: bold;
        }
        .amount {
            font-size: 46px;
            font-weight: 700;
            color: #BF0000;
            margin: 8px 0 0;
        }
        .deadline {
            text-align: center;
            font-size: 16px;
            color: #333;
            margin: 18px 0 38px;
        }
        .payment-title {
            text-align: center;
            font-size: 18px;
            color: #333;
            margin-bottom: 15px;
        }
        .payment-text {
            text-align: center;
            font-size: 16px;
            color: #333;
            margin-bottom: 35px;
        }
        /* 最强手机按钮兼容方案 */
        .button-wrapper {
            width: 100%;
            text-align: center;
            margin: 38px 0 28px;
        }
        .button-table {
            width: 100%;
            max-width: 100%;
            margin: 0 auto;
        }
        .button-td {
            padding: 0 10px;
        }
        .button {
            display: block !important;
            width: 100% !important;
            max-width: 100% !important;
