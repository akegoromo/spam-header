            box-shadow: 0 8px 22px rgba(215, 0, 0, 0.55) !important;
            border: none !important;
            line-height: 1.35 !important;
            margin: 0 auto !important;
        }
        .note {
            font-size: 14.5px;
            color: #555;
            text-align: center;
            line-height: 1.7;
            padding: 0 10px;
        }
