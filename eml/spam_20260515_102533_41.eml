  <style>
    @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Lato:wght@400;700&display=swap');

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background-color: #f5f0eb;
      font-family: 'Lato', Arial, sans-serif;
      color: #222;
    }

    .email-wrapper {
      max-width: 600px;
      margin: 0 auto;
      background-color: #f5f0eb;
    }

    /* ── HERO ── */
    .hero {
      position: relative;
      background-color: #f5f0eb;
      text-align: center;
      padding: 0;
      overflow: hidden;
    }

    .hero-headline {
      background-color: #c8102e;
      padding: 28px 32px 20px;
    }

    .hero-headline h1 {
      font-family: 'Bebas Neue', Impact, sans-serif;
      font-size: 72px;
      line-height: 1;
      color: #fff;
      letter-spacing: 2px;
      text-transform: uppercase;
    }

    .hero-image {
      display: block;
      width: 100%;
      max-height: 420px;
      object-fit: cover;
      background: linear-gradient(180deg, #f5f0eb 0%, #e8e0d8 100%);
      padding: 32px 0 0;
    }

    /* Toothbrush placeholder (shown when no actual image is embedded) */
    .toothbrush-placeholder {
      background: linear-gradient(180deg, #f5f0eb 10%, #e0d8cf 100%);
      padding: 40px 20px 0;
      text-align: center;
    }

    .brush-stage {
      display: inline-flex;
      align-items: flex-end;
      justify-content: center;
      gap: 16px;
      position: relative;
    }

    .charging-base {
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 280px;
      height: 36px;
      background: #c8102e;
      border-radius: 18px 18px 6px 6px;
    }

    .brush {
      width: 52px;
      height: 240px;
      border-radius: 26px 26px 10px 10px;
      position: relative;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .brush-head {
      width: 30px;
      height: 50px;
      border-radius: 15px 15px 4px 4px;
      background: linear-gradient(180deg, #f0c060 0%, #d4a030 100%);
      margin-bottom: 4px;
    }

    .brush-body-pink {
      flex: 1;
      width: 100%;
      border-radius: 26px 26px 10px 10px;
      background: linear-gradient(180deg, #f9d0d8 0%, #e8a0b0 50%, #d08090 100%);
      box-shadow: inset -4px 0 12px rgba(0,0,0,0.08);
    }

    .brush-body-white {
      flex: 1;
      width: 100%;
      border-radius: 26px 26px 10px 10px;
      background: linear-gradient(180deg, #f8f8f8 0%, #e0e0e0 50%, #c8c8c8 100%);
      box-shadow: inset -4px 0 12px rgba(0,0,0,0.10);
    }

    .brush-button {
      position: absolute;
      top: 80px;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: rgba(255,255,255,0.6);
      border: 2px solid rgba(255,255,255,0.9);
    }

    .glass {
      width: 48px;
      height: 64px;
      border-radius: 6px 6px 10px 10px;
      background: rgba(200,220,240,0.25);
      border: 2px solid rgba(200,220,240,0.45);
      position: absolute;
      bottom: 36px;
      z-index: 1;
    }

    .glass-left  { left: 68px; }
    .glass-right { right: 68px; }

    /* ── CTA BUTTON ── */
    .cta-section {
      text-align: center;
      padding: 36px 32px;
    }

    .cta-btn {
      display: inline-block;
      background-color: #c8102e;
      color: #fff;
      font-family: 'Lato', sans-serif;
      font-size: 15px;
      font-weight: 700;
      letter-spacing: 0.5px;
      text-decoration: none;
      padding: 16px 48px;
      border-radius: 50px;
      border: none;
      cursor: pointer;
      transition: background 0.2s ease;
    }

    .cta-btn:hover {
      background-color: #a00020;
    }

    /* ── PRODUCT SECTION ── */
    .product-section {
      padding: 0 32px 36px;
      text-align: center;
    }

    .product-title-wrap {
      display: inline-block;
      background-color: #c8102e;
      padding: 10px 18px;
      margin-bottom: 24px;
    }

    .product-title-wrap h2 {
      font-family: 'Bebas Neue', Impact, sans-serif;
      font-size: 42px;
      line-height: 1.1;
      color: #fff;
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    .product-description {
      font-size: 15px;
      line-height: 1.7;
      color: #444;
      max-width: 420px;
      margin: 0 auto 32px;
    }

    /* ── FOOTER ── */
    .footer {
      padding: 24px 32px 32px;
      text-align: center;
      border-top: 1px solid rgba(0,0,0,0.08);
    }

    .footer p {
      font-size: 11px;
      color: #888;
      line-height: 1.7;
      margin-bottom: 6px;
    }

    .footer a {
      color: #888;
      text-decoration: underline;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 480px) {
