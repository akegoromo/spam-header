<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ViewFreeScore - 3 Credit Scores</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: Arial, sans-serif;
            background-color: #f5f5f5;
            padding: 20px;
        }
        
        .container {
            max-width: 600px;
            margin: 0 auto;
            background-color: white;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }
        
        /* Header */
        .header {
            background: linear-gradient(135deg, #d4e4f7 0%, #e8f0f7 100%);
            padding: 20px;
            display: flex;
            align-items: center;
            gap: 15px;
            border-bottom: 3px solid #0066cc;
        }
        
        .logo {
            width: 50px;
            height: 50px;
            background-color: #0066cc;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 28px;
            border: 3px solid black;
        }
        
        .header-text {
            font-size: 28px;
            font-weight: bold;
        }
        
        .header-text .free {
            color: #0066cc;
        }
        
        /* Main Content */
        .content {
            padding: 40px 20px;
            text-align: center;
        }
        
        .subtitle {
            color: #666;
            font-size: 14px;
            letter-spacing: 1px;
            margin-bottom: 15px;
        }
        
        .main-heading {
            font-size: 42px;
            color: #0066cc;
            font-weight: bold;
            line-height: 1.2;
            margin-bottom: 30px;
        }
        
        /* Credit Score Section */
        .credit-score-header {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin: 30px 0 10px 0;
            color: #666;
        }
        
        .credit-score-header::before {
            content: "📊";
            font-size: 24px;
        }
        
        .credit-score-header h2 {
            font-size: 18px;
            font-weight: bold;
            letter-spacing: 2px;
        }
        
        .question {
            color: #333;
            font-size: 14px;
            margin: 20px 0;
            font-weight: bold;
        }
        
        /* Rating Scale */
        .rating-scale {
            display: flex;
            justify-content: space-around;
            margin: 30px 0;
            padding: 0 10px;
        }
        
        .rating-item {
            text-align: center;
        }
        
        .rating-number {
            font-size: 24px;
            font-weight: bold;
            color: #ff9900;
            margin-bottom: 5px;
        }
        
        .rating-star {
            font-size: 20px;
            margin: 0 5px;
            display: inline-block;
        }
        
        .rating-label {
            font-size: 12px;
            font-weight: bold;
            color: #333;
            margin-top: 8px;
        }
        
        .rating-score {
            font-size: 18px;
            font-weight: bold;
            color: #d9534f;
            margin-top: 5px;
        }
        
        /* CTA Button */
        .cta-button {
            background-color: #ff9900;
            color: white;
            border: none;
            padding: 18px 40px;
            font-size: 18px;
            font-weight: bold;
            border-radius: 6px;
            cursor: pointer;
            margin: 40px 0;
            width: 90%;
            transition: background-color 0.3s ease;
            letter-spacing: 1px;
        }
        
        .cta-button:hover {
            background-color: #e68900;
        }
        
        .cta-button::after {
            content: " ➜";
        }
        
        /* Bureau Logos */
        .bureau-logos {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin: 30px 0;
            padding: 20px 0;
            border-top: 1px solid #eee;
            border-bottom: 1px solid #eee;
        }
        
        .logo-text {
            font-size: 18px;
            font-weight: bold;
        }
        
        .logo-equifax {
            color: #d9534f;
        }
        
        .logo-experian {
            color: #6f42c1;
        }
        
        .logo-transunion {
            color: #00bcd4;
        }
        
        /* Footer */
        .footer {
            padding: 20px;
            text-align: center;
            color: #999;
            font-size: 12px;
        }
        
        .footer-text {
            margin: 8px 0;
            line-height: 1.6;
        }
        
        .footer a {
            color: #0066cc;
            text-decoration: none;
        }
        
        .footer a:hover {
            text-decoration: underline;
        }
        
        @media (max-width: 480px) {
            .header-text {
                font-size: 22px;
            }
            
            .main-heading {
                font-size: 32px;
            }
            
            .rating-scale {
                flex-wrap: wrap;
                gap: 15px;
            }
            
            .bureau-logos {
                flex-wrap: wrap;
                gap: 20px;
            }
        }
    </style>
</head>
