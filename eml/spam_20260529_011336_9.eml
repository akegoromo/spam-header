<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Depo-Provera Lawsuit Notice</title>
    <style>
        /* Styles globaux pour un rendu propre */
        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            background-color: #e9ecef;
            margin: 0;
            padding: 20px 10px;
            color: #333333;
        }

        /* Conteneur principal style "carte" */
        .email-container {
            max-width: 600px;
            margin: 0 auto;
            background-color: #ffffff;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        /* Bannière d'alerte en haut */
        .alert-banner {
            background-color: #d32f2f; /* Rouge vif mais pas fluorescent */
            color: #ffffff;
            text-align: center;
            padding: 15px 20px;
            font-size: 18px;
            font-weight: bold;
            letter-spacing: 0.5px;
        }

        /* Corps du message */
        .content {
            padding: 30px 40px;
            text-align: center;
        }

        .main-title {
            color: #0d47a1; /* Bleu marine, inspire confiance/légal */
            font-size: 32px;
            font-weight: 900;
            margin-top: 0;
            margin-bottom: 5px;
            letter-spacing: 1px;
        }

        .sub-title {
            color: #e65100; /* Orange foncé/or pour attirer l'oeil */
            font-size: 18px;
            font-weight: bold;
            margin-top: 0;
            margin-bottom: 30px;
        }

        /* Section des critères d'éligibilité */
        .criteria-box {
            background-color: #f8f9fa;
            border-left: 5px solid #0d47a1;
            padding: 20px;
            text-align: left;
            border-radius: 4px;
            margin-bottom: 35px;
        }

        .criteria-box h3 {
            margin-top: 0;
            font-size: 20px;
            color: #212529;
            text-decoration: underline;
        }

        .check-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .check-list li {
            position: relative;
            padding-left: 35px;
            margin-bottom: 12px;
            font-size: 15px;
            line-height: 1.5;
            color: #495057;
            font-weight: 500;
        }

        /* Utilisation d'un emoji pour remplacer les images de coche verte */
        .check-list li::before {
            content: '✅';
            position: absolute;
            left: 0;
            top: 0;
            font-size: 18px;
        }

        /* Bouton d'action */
        .btn-qualify {
            display: inline-block;
            background-color: #28a745; /* Vert appel à l'action */
            color: #ffffff;
            text-decoration: none;
            font-size: 22px;
            font-weight: bold;
            padding: 15px 45px;
            border-radius: 50px;
            text-transform: uppercase;
            box-shadow: 0 4px 6px rgba(40, 167, 69, 0.3);
            transition: background-color 0.3s;
        }

        .btn-qualify:hover {
            background-color: #218838;
        }

        /* Pied de page (Mentions légales) */
        .footer {
            background-color: #f1f3f5;
            padding: 20px;
            text-align: center;
            font-size: 11px;
            color: #6c757d;
            line-height: 1.6;
        }

        .footer a {
            color: #0d47a1;
            text-decoration: underline;
        }

        .divider {
            height: 1px;
            background-color: #dee2e6;
            margin: 15px 0;
            border: none;
        }

        /* Responsivité pour mobiles */
        @media (max-width: 500px) {
            .content { padding: 20px; }
            .main-title { font-size: 26px; }
            .btn-qualify { font-size: 18px; width: 100%; box-sizing: border-box; }
        }
    </style>
</head>
<body>

